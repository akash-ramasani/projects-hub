# ─── Single allowed sign-in email (required) ────────────────────────────────
# Lock the UI to exactly one account. Anyone else gets "Access denied" even if
# they exist in Firebase Auth. Must match the email you create in Firebase
# Console → Authentication → Users.
NEXT_PUBLIC_ALLOWED_EMAIL=you@example.com

# ─── Branding (optional but recommended for forks) ──────────────────────────
NEXT_PUBLIC_SITE_NAME=Projects Hub
NEXT_PUBLIC_OWNER_NAME=Your Name
NEXT_PUBLIC_SITE_URL=https://projects.example.com

# ─── Firebase Web SDK (public — exposed to the browser) ─────────────────────
# Get these from Firebase Console → Project settings → Your apps → Web app.
# These keys are NOT secret on their own — security is enforced by Firestore
# rules and the NEXT_PUBLIC_ALLOWED_EMAIL gate. Still, treat them as your own.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (server only — NEVER commit) ────────────────────────
# Paste the full contents of your service-account JSON as a SINGLE LINE.
# Newlines inside `private_key` must stay escaped as \n.
#
# Generate via: Firebase Console → Project settings → Service accounts →
#               "Generate new private key"
#
# Quick way to one-line it:
#   node -e "console.log(JSON.stringify(require('./serviceAccount.json')))"
#
FIREBASE_SERVICE_ACCOUNT=

# ─── Shared secret for the browser extension upload endpoint ────────────────
# Any long random string. The extension must send the same value in the
# `x-api-key` header. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UPLOAD_API_KEY=
